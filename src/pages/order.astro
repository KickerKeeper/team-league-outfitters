---
import Base from '../layouts/Base.astro';
import { TOWNS } from '../lib/towns';
import { getWeekOfLabel } from '../lib/week';
const weekOf = getWeekOfLabel();
---

<Base
  title="Order a Jersey — Georgetown Jerseys"
  description="Order your child's jersey. Choose your town to get started. Georgetown, MA."
>
  <section class="page-header">
    <div class="container">
      <h1>Order a Jersey</h1>
      <p>Choose your town to get started.</p>
    </div>
  </section>

  <section class="section">
    <div class="container order-layout">
      <div class="towns-area">
        <div class="towns-grid">
          {TOWNS.map((town) => (
            <a href={`/order/${town.slug}`} class="town-card">
              <h2>{town.name}</h2>
              <p>{town.blurb}</p>
              <span class="town-cta">Order &rarr;</span>
            </a>
          ))}
        </div>

        <p class="towns-note">
          Don't see your town? <a href="/contact">Get in touch</a> &mdash; we may be able to help.
        </p>
      </div>

      <aside class="order-sidebar">
        <div class="sidebar-card card">
          <h3>Prefer to call?</h3>
          <p>We're happy to help over the phone.</p>
          <p class="sidebar-phone"><a href="tel:+19783528240">(978) 352-8240</a></p>
          <p class="sidebar-phone"><a href="tel:+19783604359">(978) 360-4359</a></p>
          <hr />
          <h4>Hours &mdash; Week of {weekOf}</h4>
          <p>Wed &ndash; Fri: 11am &ndash; 5pm<br />Sat: 8am &ndash; Noon</p>
          <p class="sidebar-hours-note">Hours vary weekly &mdash; call ahead to confirm.</p>
          <hr />
          <h4>Visit Us</h4>
          <p>103 E Main St #2<br />Georgetown, MA 01833</p>
        </div>
      </aside>
    </div>
  </section>
</Base>

<style>
  .page-header {
    background: var(--color-primary);
    color: #fff;
    padding: var(--space-12) var(--space-6);
    text-align: center;
  }

  .page-header h1 { color: #fff; margin-bottom: var(--space-3); }
  .page-header p { opacity: 0.9; max-width: 520px; margin: 0 auto; }

  .order-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .order-layout {
      grid-template-columns: 1fr 300px;
      align-items: start;
    }
  }

  .towns-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 600px) {
    .towns-grid {
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }
  }

  .town-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .town-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .town-card h2 {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin: 0;
  }

  .town-card p {
    color: var(--color-neutral-600);
    font-size: var(--text-sm);
    margin: 0;
  }

  .town-cta {
    margin-top: var(--space-2);
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-primary);
  }

  .towns-note {
    margin-top: var(--space-6);
    color: var(--color-neutral-600);
    font-size: var(--text-sm);
  }

  /* Sidebar (matches existing order page) */
  .sidebar-card {
    position: sticky;
    top: calc(var(--header-height) + var(--space-6));
  }

  .sidebar-card h3 { font-size: var(--text-xl); margin-bottom: var(--space-2); }
  .sidebar-card h4 { font-size: var(--text-base); margin-bottom: var(--space-1); }
  .sidebar-card p { font-size: var(--text-sm); color: var(--color-neutral-600); }

  .sidebar-phone a {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-lg);
    color: var(--color-primary);
  }

  .sidebar-card hr {
    border: none;
    border-top: 1px solid var(--color-neutral-200);
    margin: var(--space-4) 0;
  }

  .sidebar-hours-note {
    font-size: var(--text-xs);
    color: var(--color-neutral-900);
    background: var(--color-accent-light);
    border-left: 3px solid var(--color-accent);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    margin-top: var(--space-2);
    line-height: 1.4;
  }
</style>
