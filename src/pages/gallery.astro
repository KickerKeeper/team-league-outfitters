---
import Base from '../layouts/Base.astro';
import CTABanner from '../components/CTABanner.astro';

const photos = Array.from({ length: 10 }, (_, i) => ({
  src: `/images/photos/photo-${String(i + 1).padStart(2, '0')}.png`,
  alt: `Youth sports team outfitted by Georgetown Jerseys — photo ${i + 1}`,
}));
---

<Base
  title="Our Teams — Georgetown Jerseys"
  description="See the teams we've outfitted. Youth soccer, basketball, and baseball teams from Georgetown and the North Shore."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Our Teams</h1>
      <p>Real teams from Georgetown and the North Shore — suited up and ready to play.</p>
    </div>
  </section>

  <!-- Gallery -->
  <section class="section">
    <div class="container">
      <div class="gallery-grid">
        {photos.map((photo, index) => (
          <button class="gallery-item" data-index={index} aria-label={`View ${photo.alt}`}>
            <img src={photo.src} alt={photo.alt} width="600" height="338" loading="lazy" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <dialog class="lightbox" id="lightbox" aria-label="Photo viewer">
    <div class="lightbox-content">
      <button class="lightbox-close" id="lightbox-close" aria-label="Close photo viewer">&times;</button>
      <button class="lightbox-prev" id="lightbox-prev" aria-label="Previous photo">&#8249;</button>
      <img class="lightbox-img" id="lightbox-img" src="" alt="" />
      <button class="lightbox-next" id="lightbox-next" aria-label="Next photo">&#8250;</button>
    </div>
  </dialog>

  <CTABanner
    headline="Want your team up here?"
    subtext="Let's get your team outfitted. It starts with a quick form."
    buttonText="Get Started"
  />
</Base>

<style>
  .page-header {
    background: var(--color-primary);
    color: #fff;
    padding: var(--space-12) var(--space-6);
    text-align: center;
  }

  .page-header h1 {
    color: #fff;
    margin-bottom: var(--space-3);
  }

  .page-header p {
    opacity: 0.9;
    max-width: 520px;
    margin: 0 auto;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .gallery-item {
    border: none;
    padding: 0;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .gallery-item:hover img {
    transform: scale(1.03);
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Lightbox (dialog) */
  .lightbox {
    border: none;
    background: rgba(0, 0, 0, 0.9);
    max-width: 100vw;
    max-height: 100vh;
    width: 100vw;
    height: 100vh;
    padding: 0;
    margin: 0;
    position: fixed;
    inset: 0;
  }

  .lightbox::backdrop {
    background: transparent;
  }

  .lightbox-content {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: var(--radius-lg);
  }

  .lightbox-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    background: none;
    border: none;
    color: #fff;
    font-size: 2.5rem;
    cursor: pointer;
    padding: var(--space-2);
    line-height: 1;
    z-index: 10;
  }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.15);
    border: none;
    color: #fff;
    font-size: 2.5rem;
    cursor: pointer;
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-lg);
    z-index: 10;
  }

  .lightbox-prev:hover,
  .lightbox-next:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .lightbox-prev { left: var(--space-4); }
  .lightbox-next { right: var(--space-4); }
</style>

<script>
  const photos = Array.from({ length: 10 }, (_, i) => ({
    src: `/images/photos/photo-${String(i + 1).padStart(2, '0')}.png`,
    alt: `Youth sports team outfitted by Georgetown Jerseys — photo ${i + 1}`,
  }));

  const dialog = document.getElementById('lightbox') as HTMLDialogElement;
  const img = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = document.getElementById('lightbox-close') as HTMLButtonElement;
  const prevBtn = document.getElementById('lightbox-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('lightbox-next') as HTMLButtonElement;
  let current = 0;

  function show(index: number) {
    current = index;
    img.src = photos[current].src;
    img.alt = photos[current].alt;
    dialog.showModal();
  }

  function navigate(dir: number) {
    current = (current + dir + photos.length) % photos.length;
    img.src = photos[current].src;
    img.alt = photos[current].alt;
  }

  document.querySelectorAll('.gallery-item').forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = parseInt((btn as HTMLElement).dataset.index || '0');
      show(index);
    });
  });

  closeBtn.addEventListener('click', () => dialog.close());
  prevBtn.addEventListener('click', () => navigate(-1));
  nextBtn.addEventListener('click', () => navigate(1));

  dialog.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });

  dialog.addEventListener('click', (e) => {
    if (e.target === dialog) dialog.close();
  });
</script>
