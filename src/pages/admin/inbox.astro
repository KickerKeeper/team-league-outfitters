---
export const prerender = false;
import Admin from '../../layouts/Admin.astro';
---

<Admin title="Inbox" activeTab="inbox">
  <div class="inbox-header">
    <div class="inbox-header-left">
      <h1>Inbox</h1>
      <span class="inbox-count" id="inbox-count"></span>
      <button class="refresh-btn" id="refresh-btn" onclick="loadInbox()" title="Refresh">&#8635;</button>
      <a href="/api/inbox/export" class="refresh-btn" title="Export CSV" style="text-decoration:none;">&#8615;</a>
    </div>
    <span class="filter-count" id="count-new" style="display:none;"></span>
  </div>

  <div class="inbox-layout">
    <div class="inbox-left">
      <div class="type-tabs">
        <button class="type-tab active" data-type="order">Orders</button>
        <button class="type-tab" data-type="email">Emails</button>
      </div>
      <div class="stage-toggle" id="stage-toggle">
        <button class="stg-btn active" data-stg="all">All</button>
        <button class="stg-btn" data-stg="open">Open</button>
        <button class="stg-btn" data-stg="closed">Closed</button>
      </div>
      <div class="search-bar">
        <input type="text" id="search-input" placeholder="Search name, team, org..." oninput="renderList()" />
      </div>
      <div class="inbox-list" id="inbox-list">
        <div class="inbox-loading"><div class="loading-dot"></div><p>Loading...</p></div>
      </div>
    </div>
    <div class="inbox-detail" id="inbox-detail">
      <div class="detail-placeholder"><div class="placeholder-icon">&#9993;</div><p>Select an item to view details</p></div>
    </div>
  </div>
</Admin>

<style is:global>
  /* Header */
  .inbox-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: var(--space-6); flex-wrap: wrap; gap: var(--space-3); }
  .inbox-header-left { display: flex; align-items: center; gap: var(--space-3); }
  .inbox-header h1 { font-size: var(--text-2xl); }
  .inbox-count { font-size: var(--text-sm); color: var(--color-neutral-600); background: var(--color-neutral-50); padding: 2px 10px; border-radius: var(--radius-full); }
  .refresh-btn { background: none; border: 1px solid var(--color-neutral-200); border-radius: var(--radius-md); width: 32px; height: 32px; font-size: 1.1rem; cursor: pointer; color: var(--color-neutral-600); display: flex; align-items: center; justify-content: center; transition: all var(--transition-fast); }
  .refresh-btn:hover { color: var(--color-primary); border-color: var(--color-primary); }
  .refresh-btn.spinning { animation: spin 0.6s ease; }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .filter-count { display: none; }

  /* Layout */
  .inbox-layout { display: grid; grid-template-columns: 1fr; gap: 0; min-height: 600px; border: 1px solid var(--color-neutral-200); border-radius: var(--radius-xl); overflow: hidden; background: #fff; }
  @media (min-width: 768px) { .inbox-layout { grid-template-columns: 360px 1fr; } }
  .inbox-left { display: flex; flex-direction: column; border-right: 1px solid var(--color-neutral-200); }

  /* Type tabs above list */
  .type-tabs { display: flex; border-bottom: 1px solid var(--color-neutral-200); flex-shrink: 0; }
  .type-tab { flex: 1; padding: 12px; font-family: var(--font-heading); font-size: var(--text-sm); font-weight: 600; border: none; background: var(--color-neutral-50); color: var(--color-neutral-600); cursor: pointer; transition: all var(--transition-fast); text-transform: uppercase; letter-spacing: 0.5px; }
  .type-tab:first-child { border-right: 1px solid var(--color-neutral-200); }
  .type-tab.active { background: #fff; color: var(--color-primary); box-shadow: inset 0 -2px 0 var(--color-primary); }
  .type-tab:hover:not(.active) { color: var(--color-neutral-900); }

  /* Stage toggle */
  .stage-toggle { display: flex; border-bottom: 1px solid var(--color-neutral-200); flex-shrink: 0; padding: 6px 6px; gap: 3px; background: var(--color-neutral-50); overflow: hidden; }
  .stg-btn { font-family: var(--font-heading); font-size: 9px; font-weight: 600; padding: 4px 7px; border: 1px solid transparent; background: none; color: var(--color-neutral-600); cursor: pointer; border-radius: var(--radius-full); transition: all var(--transition-fast); text-transform: uppercase; letter-spacing: 0.2px; white-space: nowrap; flex-shrink: 0; }
  .stg-btn:hover { color: var(--color-neutral-900); background: #fff; }
  .stg-btn.active { background: #fff; color: var(--color-primary); border-color: var(--color-neutral-200); box-shadow: var(--shadow-sm); }

  /* Search */
  .search-bar { padding: 8px; border-bottom: 1px solid var(--color-neutral-200); flex-shrink: 0; }
  .search-bar input { width: 100%; padding: 8px 12px; border: 1px solid var(--color-neutral-200); border-radius: var(--radius-full); font-size: var(--text-sm); font-family: var(--font-body); background: var(--color-neutral-50); }
  .search-bar input:focus { outline: none; border-color: var(--color-primary); background: #fff; }

  .inbox-list { overflow-y: auto; max-height: calc(75vh - 130px); flex: 1; }
  .inbox-loading { padding: var(--space-12); text-align: center; color: var(--color-neutral-600); display: flex; flex-direction: column; align-items: center; gap: var(--space-3); }
  .loading-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--color-primary); animation: pulse 1s ease infinite; }
  @keyframes pulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }

  /* List items */
  .inbox-item { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-neutral-50); cursor: pointer; transition: background var(--transition-fast); position: relative; }
  .inbox-item:hover { background: var(--color-neutral-50); }
  .inbox-item.selected { background: rgba(43, 94, 167, 0.05); }
  .inbox-item.selected::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--color-primary); }
  .inbox-item-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2px; }
  .inbox-item-name { font-family: var(--font-heading); font-size: var(--text-sm); font-weight: 600; color: var(--color-neutral-900); display: flex; align-items: center; gap: 8px; }
  .inbox-item.is-new .inbox-item-name::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--color-primary); flex-shrink: 0; }
  .inbox-item-date { font-size: var(--text-xs); color: var(--color-neutral-600); flex-shrink: 0; }
  .inbox-item-preview { font-size: var(--text-xs); color: var(--color-neutral-600); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4px; }
  .inbox-item-tags { display: flex; gap: 4px; flex-wrap: wrap; }
  .tag { font-size: 9px; padding: 1px 7px; border-radius: var(--radius-full); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  .tag-open { background: #fff3e0; color: #e65100; }
  .tag-closed { background: var(--color-neutral-50); color: var(--color-neutral-600); }
  .tag-paid { background: #e8f5e9; color: #2e7d32; border: 1px solid #2e7d32; }

  /* Detail panel */
  .inbox-detail { overflow-y: auto; max-height: 75vh; }
  .detail-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; min-height: 400px; color: var(--color-neutral-600); gap: var(--space-3); }
  .placeholder-icon { font-size: 3rem; opacity: 0.3; }

  /* Detail top — fixed padding */
  .detail-top { padding: var(--space-6) var(--space-8); border-bottom: 1px solid var(--color-neutral-200); background: var(--color-neutral-50); }
  .detail-top-row { display: flex; justify-content: space-between; align-items: flex-start; gap: var(--space-4); flex-wrap: wrap; }
  .detail-name-row { display: flex; align-items: center; gap: var(--space-3); }
  .detail-name { font-family: var(--font-heading); font-size: var(--text-xl); font-weight: 700; color: var(--color-neutral-900); }
  .detail-type-badge { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; padding: 2px 10px; border-radius: var(--radius-full); }
  .detail-type-order { background: #e3f2fd; color: #1565c0; } .detail-type-email { background: #fce4ec; color: #c62828; }
  .detail-meta { font-size: var(--text-sm); color: var(--color-neutral-600); margin-top: 2px; }
  .detail-contact { display: flex; gap: var(--space-6); margin-top: var(--space-3); flex-wrap: wrap; }
  .detail-contact a { font-size: var(--text-sm); color: var(--color-primary); text-decoration: none; display: flex; align-items: center; gap: 4px; }
  .detail-contact a:hover { text-decoration: underline; }
  .contact-icon { font-size: var(--text-base); }
  .detail-actions { display: flex; gap: var(--space-2); flex-shrink: 0; padding-top: 2px; }
  .action-btn { font-family: var(--font-heading); font-size: var(--text-xs); font-weight: 600; padding: 6px 14px; border-radius: var(--radius-md); cursor: pointer; border: 1px solid var(--color-neutral-200); background: #fff; transition: all var(--transition-fast); text-transform: uppercase; letter-spacing: 0.5px; }
  .action-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .action-btn.complete-btn { background: var(--color-success); color: #fff; border-color: var(--color-success); }
  .action-btn.complete-btn:hover { filter: brightness(0.9); color: #fff; }
  .action-btn.delete-btn { color: var(--color-neutral-600); }
  .action-btn.paid-btn { color: var(--color-neutral-600); }
  .action-btn.paid-btn:hover { border-color: var(--color-success); color: var(--color-success); }
  .action-btn.paid-btn.paid-active { background: var(--color-success); color: #fff; border-color: var(--color-success); }
  .action-btn.paid-btn.paid-active:hover { filter: brightness(0.92); color: #fff; }
  .action-btn.close-btn { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .action-btn.close-btn:hover { background: var(--color-primary-dark); color: #fff; }
  .action-btn.close-btn.reopen { background: #fff; color: var(--color-neutral-600); border-color: var(--color-neutral-200); }
  .action-btn.close-btn.reopen:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .action-btn.delete-btn:hover { color: var(--color-error); border-color: var(--color-error); }
  /* Status tag in list */
  .inbox-item-stage { font-size: 9px; font-weight: 600; color: var(--color-neutral-600); margin-top: 2px; }

  /* Detail body */
  .detail-body { padding: var(--space-6) var(--space-8); }
  .detail-section { margin-bottom: var(--space-5); }
  .detail-section:last-child { margin-bottom: 0; }
  .detail-section-title { font-family: var(--font-heading); font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--color-neutral-600); margin-bottom: var(--space-3); padding-bottom: var(--space-2); border-bottom: 1px solid var(--color-neutral-200); }
  .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3) var(--space-6); }
  .detail-grid .field-item.full-width { grid-column: 1 / -1; }
  @media (max-width: 1023px) { .detail-grid { grid-template-columns: 1fr; } }
  .field-item { display: flex; flex-direction: column; gap: 4px; background: var(--color-neutral-50); padding: 10px 14px; border-radius: var(--radius-md); border: 1px solid var(--color-neutral-200); }
  .field-label { font-size: 10px; font-weight: 700; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.8px; }
  .field-value { font-size: var(--text-sm); color: var(--color-neutral-900); white-space: pre-wrap; line-height: 1.5; font-weight: 400; }
  .field-value.empty { color: var(--color-neutral-600); font-style: italic; }

  /* Messages section */
  .msgs-section { padding: var(--space-6) var(--space-8); border-top: 1px solid var(--color-neutral-200); background: var(--color-neutral-50); }
  .msgs-section-header { display: flex; align-items: center; gap: var(--space-4); margin-bottom: var(--space-4); }
  .msgs-tab { font-family: var(--font-heading); font-size: var(--text-xs); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; padding: 6px 14px; border: none; background: none; color: var(--color-neutral-600); cursor: pointer; border-radius: var(--radius-full); transition: all var(--transition-fast); }
  .msgs-tab.active { background: var(--color-primary); color: #fff; }
  .msgs-tab:hover:not(.active) { color: var(--color-neutral-900); background: var(--color-neutral-200); }
  .msgs-panel { display: none; }
  .msgs-panel.active { display: block; }

  /* Compose box */
  .compose-box { background: #fff; border: 1px solid var(--color-neutral-200); border-radius: var(--radius-lg); overflow: hidden; margin-bottom: var(--space-4); }
  .compose-textarea { width: 100%; min-height: 80px; padding: var(--space-3) var(--space-4); border: none; font-family: var(--font-body); font-size: var(--text-sm); resize: vertical; line-height: 1.6; color: var(--color-neutral-900); }
  .compose-textarea:focus { outline: none; }
  .compose-toolbar { display: flex; justify-content: flex-end; padding: var(--space-2) var(--space-3); border-top: 1px solid var(--color-neutral-200); }
  .compose-send { background: var(--color-primary); color: #fff; border: none; padding: 8px 20px; border-radius: var(--radius-md); font-family: var(--font-heading); font-weight: 600; font-size: var(--text-sm); cursor: pointer; transition: background var(--transition-fast); }
  .compose-send:hover { background: var(--color-primary-dark); }
  .compose-send:disabled { opacity: 0.6; cursor: not-allowed; }

  /* Message bubbles */
  .msg-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .msg-bubble { background: #fff; border: 1px solid var(--color-neutral-200); border-radius: var(--radius-lg); padding: var(--space-3) var(--space-4); cursor: pointer; transition: all var(--transition-fast); }
  .msg-bubble:hover { box-shadow: var(--shadow-sm); }
  .msg-bubble.msg-sent { border-left: 3px solid var(--color-primary); }
  .msg-bubble.msg-received { border-left: 3px solid var(--color-accent); background: var(--color-accent-light); }
  .msg-bubble.msg-note { border-left: 3px solid var(--color-neutral-200); background: #fff; }
  .msg-bubble-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-1); }
  .msg-bubble-who { font-size: var(--text-xs); font-weight: 600; color: var(--color-primary); }
  .msg-bubble.msg-received .msg-bubble-who { color: #b8860b; }
  .msg-bubble.msg-note .msg-bubble-who { color: var(--color-neutral-600); }
  .msg-bubble-date { font-size: var(--text-xs); color: var(--color-neutral-600); }
  .msg-bubble-body { font-size: var(--text-sm); color: var(--color-neutral-900); line-height: 1.6; white-space: pre-wrap; }

  .msg-empty { font-size: var(--text-sm); color: var(--color-neutral-600); font-style: italic; text-align: center; padding: var(--space-4); }

  .inbox-empty { padding: var(--space-12); text-align: center; color: var(--color-neutral-600); display: flex; flex-direction: column; align-items: center; gap: var(--space-2); }
  .inbox-empty-icon { font-size: 2rem; opacity: 0.3; margin-bottom: var(--space-2); }

  .msg-bubble[onclick] { cursor: pointer; }
  .msg-bubble[onclick]:hover { box-shadow: var(--shadow-md); }

  /* Full email modal */
  .email-modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: var(--space-4); }
  .email-modal { background: #fff; border-radius: var(--radius-xl); max-width: 700px; width: 100%; max-height: 80vh; display: flex; flex-direction: column; box-shadow: 0 8px 32px rgba(0,0,0,0.2); }
  .email-modal-header { display: flex; justify-content: space-between; align-items: center; padding: var(--space-4) var(--space-6); border-bottom: 1px solid var(--color-neutral-200); flex-shrink: 0; }
  .email-modal-header h3 { font-size: var(--text-base); font-weight: 600; }
  .email-modal-close { background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-neutral-600); padding: 4px; min-width: 32px; min-height: 32px; display: flex; align-items: center; justify-content: center; }
  .email-modal-close:hover { color: var(--color-neutral-900); }
  .email-modal-meta { padding: var(--space-3) var(--space-6); background: var(--color-neutral-50); border-bottom: 1px solid var(--color-neutral-200); font-size: var(--text-sm); color: var(--color-neutral-600); flex-shrink: 0; }
  .email-modal-meta strong { color: var(--color-neutral-900); }
  .email-modal-body { padding: var(--space-6); overflow-y: auto; font-size: var(--text-sm); line-height: 1.7; white-space: pre-wrap; color: var(--color-neutral-900); }
</style>

<script is:inline>
  var allSubmissions = [];
  var currentType = 'order';
  var currentStatusFilter = 'all';
  var selectedId = null;

  var fieldSections = {
    contact: { title: 'Contact Information', fields: ['name', 'email', 'phone'] },
    team: { title: 'Team Details', fields: ['team', 'sport', 'colors', 'players'] },
    sizing: { title: 'Sizing & Numbers', fields: ['sizes', 'numbers'], fullWidth: true },
    order: { title: 'Order Preferences', fields: ['customization', 'fulfillment', 'notes'], fullWidth: true }
  };

  var fieldLabels = {
    name: 'Name', email: 'Email', phone: 'Phone',
    team: 'Team / Organization', sport: 'Sport', colors: 'Team Colors',
    players: 'Number of Players', sizes: 'Sizes & Quantities', numbers: 'Uniform Numbers',
    customization: 'Customization Type', fulfillment: 'Pickup or Ship', notes: 'Additional Notes'
  };

  function getItemType(s) { return s.formName === 'email' ? 'email' : 'order'; }

  function loadInbox() {
    var btn = document.getElementById('refresh-btn');
    btn.classList.add('spinning');
    fetch('/api/inbox/submissions').then(function(r) { return r.json(); }).then(function(data) {
      allSubmissions = data; updateCounts(); renderList(); btn.classList.remove('spinning');
    }).catch(function() {
      document.getElementById('inbox-list').innerHTML = '<div class="inbox-empty"><div class="inbox-empty-icon">&#9888;</div><p>Failed to load</p></div>';
      btn.classList.remove('spinning');
    });
  }

  function updateCounts() {
    var newCount = allSubmissions.filter(function(s) { return s.status === 'new'; }).length;
    document.getElementById('inbox-count').textContent = allSubmissions.length + ' total';
    var countEl = document.getElementById('count-new');
    countEl.textContent = newCount; countEl.style.display = newCount > 0 ? '' : 'none';
  }

  function renderList() {
    var list = document.getElementById('inbox-list');
    var filtered = allSubmissions.filter(function(s) { return getItemType(s) === currentType; });

    // Show/hide status toggle (orders only)
    document.getElementById('stage-toggle').style.display = currentType === 'order' ? 'flex' : 'none';

    // Apply open/closed filter for orders
    if (currentType === 'order' && currentStatusFilter !== 'all') {
      filtered = filtered.filter(function(s) {
        return currentStatusFilter === 'closed' ? s.status === 'completed' : s.status !== 'completed';
      });
    }

    // Apply search filter
    var searchVal = (document.getElementById('search-input').value || '').toLowerCase().trim();
    if (searchVal) {
      filtered = filtered.filter(function(s) {
        var name = (s.data.name || '').toLowerCase();
        var team = (s.data.team || '').toLowerCase();
        return name.indexOf(searchVal) !== -1 || team.indexOf(searchVal) !== -1;
      });
    }

    if (filtered.length === 0) {
      list.innerHTML = '<div class="inbox-empty"><div class="inbox-empty-icon">&#128235;</div><p>No ' + currentType + 's found</p></div>';
      return;
    }

    list.innerHTML = filtered.map(function(s) {
      var name = s.data.name || s.data.team || 'Unknown';
      var date = new Date(s.createdAt);
      var now = new Date();
      var dateStr = date.toDateString() === now.toDateString() ? date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      var orderPreview = s.data.town || s.data.jersey_count
        ? [s.data.town, s.data.jersey_count ? s.data.jersey_count + (s.data.jersey_count === '1' ? ' jersey' : ' jerseys') : ''].filter(Boolean).join(' · ')
        : [s.data.team, s.data.sport, s.data.players ? s.data.players + ' players' : ''].filter(Boolean).join(' · ');
      var preview = currentType === 'order' ? orderPreview : ((s.messages || []).slice(-1)[0] || {}).body || s.data.email || '';
      if (preview.length > 80) preview = preview.substring(0, 80) + '...';

      var stageHtml = '';
      var paidTag = s.paid ? ' <span class="tag tag-paid">Paid</span>' : '';
      if (currentType === 'order') {
        var isClosed = s.status === 'completed';
        var statusTag = '<span class="tag tag-' + (isClosed ? 'closed' : 'open') + '">' + (isClosed ? 'Closed' : 'Open') + '</span>';
        stageHtml = '<div class="inbox-item-stage">' + statusTag + paidTag + '</div>';
      } else if (s.paid) {
        stageHtml = '<div class="inbox-item-stage"><span class="tag tag-paid">Paid</span></div>';
      }

      return '<div class="inbox-item' + (s.status === 'new' ? ' is-new' : '') + (s.id === selectedId ? ' selected' : '') + '" data-id="' + s.id + '">' +
        '<div class="inbox-item-top"><span class="inbox-item-name">' + esc(name) + '</span><span class="inbox-item-date">' + dateStr + '</span></div>' +
        '<div class="inbox-item-preview">' + esc(preview) + '</div>' +
        stageHtml +
      '</div>';
    }).join('');

    list.querySelectorAll('.inbox-item').forEach(function(item) {
      item.onclick = function() { showDetail(item.dataset.id); };
    });
  }

  function showDetail(id) {
    selectedId = id;
    var sub = allSubmissions.find(function(s) { return s.id === id; });
    if (!sub) return;

    if (sub.status === 'new') {
      fetch('/api/inbox/update', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id, status: 'read' }) })
      .then(function() { sub.status = 'read'; updateCounts(); renderList(); });
    } else { renderList(); }

    var detail = document.getElementById('inbox-detail');
    var email = sub.data.email || '';
    var phone = sub.data.phone || '';
    var itemType = getItemType(sub);
    var date = new Date(sub.createdAt).toLocaleString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });

    var contactHtml = '';
    if (email) contactHtml += '<a href="mailto:' + esc(email) + '"><span class="contact-icon">&#9993;</span> ' + esc(email) + '</a>';
    if (phone) contactHtml += '<a href="tel:' + esc(phone) + '"><span class="contact-icon">&#9742;</span> ' + esc(phone) + '</a>';

    var isClosed = sub.status === 'completed';
    var paidBtnLabel = sub.paid ? '&#10003; Paid' : 'Mark Paid';
    var paidBtnTitle = sub.paid && sub.paidAt ? 'Paid on ' + new Date(sub.paidAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) + ' — click to unmark' : 'Mark this order paid';
    var closeBtnLabel = isClosed ? 'Reopen' : 'Close Order';
    var closeBtnTitle = isClosed ? 'Reopen this order' : 'Close this order and send the completion email';
    var closeBtnHtml = itemType === 'order'
      ? '<button class="action-btn close-btn' + (isClosed ? ' reopen' : '') + '" onclick="toggleClosed(\'' + id + '\')" title="' + closeBtnTitle + '">' + closeBtnLabel + '</button>'
      : '';
    var actionsHtml =
      closeBtnHtml +
      '<button class="action-btn paid-btn' + (sub.paid ? ' paid-active' : '') + '" onclick="togglePaid(\'' + id + '\')" title="' + paidBtnTitle + '">' + paidBtnLabel + '</button>' +
      '<button class="action-btn delete-btn" onclick="deleteSubmission(\'' + id + '\')">&#128465;</button>';

    // Fields
    var sectionsHtml = '';
    Object.keys(fieldSections).forEach(function(key) {
      var sec = fieldSections[key];
      var fields = sec.fields.filter(function(f) { return sub.data[f]; });
      if (!fields.length) return;
      sectionsHtml += '<div class="detail-section"><div class="detail-section-title">' + sec.title + '</div><div class="detail-grid">';
      fields.forEach(function(f) {
        sectionsHtml += '<div class="field-item' + (sec.fullWidth ? ' full-width' : '') + '"><span class="field-label">' + (fieldLabels[f] || formatLabel(f)) + '</span><span class="field-value">' + esc(sub.data[f]) + '</span></div>';
      });
      sectionsHtml += '</div></div>';
    });

    // Extra fields
    var known = []; Object.values(fieldSections).forEach(function(s) { known = known.concat(s.fields); });
    var extra = Object.keys(sub.data).filter(function(k) { return known.indexOf(k) === -1 && sub.data[k]; });
    if (extra.length) {
      sectionsHtml += '<div class="detail-section"><div class="detail-section-title">Other</div><div class="detail-grid">';
      extra.forEach(function(f) { sectionsHtml += '<div class="field-item"><span class="field-label">' + formatLabel(f) + '</span><span class="field-value">' + esc(sub.data[f]) + '</span></div>'; });
      sectionsHtml += '</div></div>';
    }

    // Split messages into emails and notes
    var msgs = (sub.messages || []).slice();
    var emails = msgs.filter(function(m) { return m.type === 'sent' || m.type === 'received'; });
    var notes = msgs.filter(function(m) { return m.type === 'note'; });

    // Sort newest first
    emails.sort(function(a, b) { return new Date(b.timestamp || b.sentAt).getTime() - new Date(a.timestamp || a.sentAt).getTime(); });
    notes.sort(function(a, b) { return new Date(b.timestamp || b.sentAt).getTime() - new Date(a.timestamp || a.sentAt).getTime(); });

    // Email list
    var emailListHtml = '';
    if (emails.length) {
      emailListHtml = '<div class="msg-list">' + emails.map(function(m, idx) {
        var mDate = new Date(m.timestamp || m.sentAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
        var who = m.type === 'sent' ? 'You &rarr; ' + esc(m.to || email) : esc(m.from || email) + ' &rarr; You';
        var preview = m.body.length > 100 ? m.body.substring(0, 100) + '...' : m.body;
        return '<div class="msg-bubble msg-' + m.type + '" onclick="showFullEmail(' + idx + ')">' +
          '<div class="msg-bubble-header"><span class="msg-bubble-who">' + who + '</span><span class="msg-bubble-date">' + mDate + '</span></div>' +
          '<div class="msg-bubble-body">' + esc(m.body) + '</div></div>';
      }).join('') + '</div>';
    } else {
      emailListHtml = '<div class="msg-empty">No emails yet</div>';
    }
    // Store emails for modal access
    window._currentEmails = emails;

    // Notes list
    var notesListHtml = '';
    if (notes.length) {
      notesListHtml = '<div class="msg-list">' + notes.map(function(m) {
        var mDate = new Date(m.timestamp || m.sentAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
        return '<div class="msg-bubble msg-note">' +
          '<div class="msg-bubble-header"><span class="msg-bubble-who">Note</span><span class="msg-bubble-date">' + mDate + '</span></div>' +
          '<div class="msg-bubble-body">' + esc(m.body) + '</div></div>';
      }).join('') + '</div>';
    } else {
      notesListHtml = '<div class="msg-empty">No notes yet</div>';
    }

    // Email compose
    var emailComposeHtml = email
      ? '<div class="compose-box"><textarea class="compose-textarea" id="email-body" placeholder="Write an email to ' + esc(email) + '..."></textarea><div class="compose-toolbar"><button class="compose-send" id="email-send" onclick="sendMsg(\'' + id + '\',\'' + esc(email) + '\',\'sent\')">Send Email</button></div></div>'
      : '<div class="msg-empty">No email address provided</div>';

    // Note compose
    var noteComposeHtml = '<div class="compose-box"><textarea class="compose-textarea" id="note-body" placeholder="Add an internal note..."></textarea><div class="compose-toolbar"><button class="compose-send" id="note-send" onclick="sendMsg(\'' + id + '\',\'\',\'note\')">Add Note</button></div></div>';

    detail.innerHTML =
      '<div class="detail-top"><div class="detail-top-row"><div>' +
        '<div class="detail-name-row"><span class="detail-name">' + esc(sub.data.name || 'Unknown') + '</span><span class="detail-type-badge detail-type-' + itemType + '">' + itemType + '</span></div>' +
        '<div class="detail-meta">' + date + '</div>' +
        (contactHtml ? '<div class="detail-contact">' + contactHtml + '</div>' : '') +
      '</div><div class="detail-actions">' + actionsHtml + '</div></div></div>' +
      (sectionsHtml ? '<div class="detail-body">' + sectionsHtml + '</div>' : '') +
      '<div class="msgs-section">' +
        '<div class="msgs-section-header">' +
          '<button class="msgs-tab active" onclick="switchMsgTab(\'emails\',this)">Emails</button>' +
          '<button class="msgs-tab" onclick="switchMsgTab(\'notes\',this)">Notes</button>' +
        '</div>' +
        '<div class="msgs-panel active" id="panel-emails">' + emailComposeHtml + emailListHtml + '</div>' +
        '<div class="msgs-panel" id="panel-notes">' + noteComposeHtml + notesListHtml + '</div>' +
      '</div>';
  }

  function showFullEmail(idx) {
    var m = window._currentEmails[idx];
    if (!m) return;
    var fullContent = m.fullBody || m.body;
    var mDate = new Date(m.timestamp || m.sentAt).toLocaleString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });
    var who = m.type === 'sent' ? 'To: ' + esc(m.to || '') : 'From: ' + esc(m.from || '');
    var subject = m.subject ? 'Subject: ' + esc(m.subject) : '';

    var overlay = document.createElement('div');
    overlay.className = 'email-modal-overlay';
    overlay.onclick = function(e) { if (e.target === overlay) overlay.remove(); };

    var typeLabel = m.type === 'sent' ? 'Sent Email' : 'Received Email';
    var hasFullContent = m.fullBody && m.fullBody !== m.body;

    overlay.innerHTML =
      '<div class="email-modal">' +
        '<div class="email-modal-header"><h3>' + typeLabel + '</h3><button class="email-modal-close" onclick="this.closest(\'.email-modal-overlay\').remove()">&times;</button></div>' +
        '<div class="email-modal-meta"><strong>' + who + '</strong><br>' + (subject ? subject + '<br>' : '') + mDate + '</div>' +
        '<div class="email-modal-body">' + esc(fullContent) + (hasFullContent ? '' : '<div style="margin-top:16px;font-style:italic;color:#6C757D;font-size:12px;">Full email thread not available for messages received before April 11, 2026.</div>') + '</div>' +
      '</div>';
    document.body.appendChild(overlay);

    var closeOnEscape = function(e) { if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', closeOnEscape); } };
    document.addEventListener('keydown', closeOnEscape);
  }

  function switchMsgTab(tab, btn) {
    document.querySelectorAll('.msgs-tab').forEach(function(t) { t.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.msgs-panel').forEach(function(p) { p.classList.remove('active'); });
    document.getElementById('panel-' + tab).classList.add('active');
  }

  function sendMsg(id, to, type) {
    var textareaId = type === 'note' ? 'note-body' : 'email-body';
    var btnId = type === 'note' ? 'note-send' : 'email-send';
    var body = document.getElementById(textareaId).value;
    if (!body.trim()) return;
    var btn = document.getElementById(btnId);
    btn.disabled = true; btn.textContent = type === 'sent' ? 'Sending...' : 'Saving...';
    var payload = { id: id, body: body, type: type };
    if (type === 'sent' && to) payload.to = to;
    fetch('/api/inbox/reply', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
    .then(function(r) { if (r.ok) return r.json(); return r.json().then(function(e) { throw new Error(e.error || 'Failed'); }); })
    .then(function(updated) { var s = allSubmissions.find(function(x) { return x.id === id; }); if (s && updated.messages) s.messages = updated.messages; showDetail(id); })
    .catch(function(err) { btn.textContent = err.message || 'Failed'; btn.disabled = false; });
  }

  var pendingUpdate = false;

  function toggleClosed(id) {
    var sub = allSubmissions.find(function(x) { return x.id === id; });
    if (!sub) return;
    if (pendingUpdate) return;
    pendingUpdate = true;
    var newStatus = sub.status === 'completed' ? 'read' : 'completed';
    sub.status = newStatus;
    renderList();
    showDetail(id);
    fetch('/api/inbox/update', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id, status: newStatus }) })
    .then(function() { pendingUpdate = false; updateCounts(); })
    .catch(function() { pendingUpdate = false; });
  }

  function updateStatus(id, status) {
    fetch('/api/inbox/update', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id, status: status }) })
    .then(function() { var s = allSubmissions.find(function(x) { return x.id === id; }); if (s) s.status = status; updateCounts(); renderList(); showDetail(id); });
  }

  function togglePaid(id) {
    var sub = allSubmissions.find(function(x) { return x.id === id; });
    if (!sub) return;
    var newPaid = !sub.paid;
    // Optimistic update
    sub.paid = newPaid;
    sub.paidAt = newPaid ? new Date().toISOString() : undefined;
    renderList();
    showDetail(id);
    fetch('/api/inbox/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: id, paid: newPaid })
    })
    .then(function(r) { return r.json(); })
    .then(function(updated) {
      if (updated && typeof updated.paid === 'boolean') {
        sub.paid = updated.paid;
        sub.paidAt = updated.paidAt;
      }
    })
    .catch(function() {
      // Revert on error
      sub.paid = !newPaid;
      sub.paidAt = !newPaid ? new Date().toISOString() : undefined;
      renderList();
      showDetail(id);
    });
  }

  function deleteSubmission(id) {
    if (!confirm('Delete this? This cannot be undone.')) return;
    fetch('/api/inbox/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: id }) })
    .then(function() { allSubmissions = allSubmissions.filter(function(s) { return s.id !== id; }); selectedId = null; updateCounts(); renderList(); document.getElementById('inbox-detail').innerHTML = '<div class="detail-placeholder"><div class="placeholder-icon">&#9993;</div><p>Select an item</p></div>'; });
  }

  function formatLabel(k) { return k.replace(/([A-Z])/g, ' $1').replace(/[_-]/g, ' ').replace(/^\w/, function(c) { return c.toUpperCase(); }); }
  function esc(s) { if (!s) return ''; var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  // Type tabs
  document.querySelectorAll('.type-tab').forEach(function(btn) {
    btn.onclick = function() {
      currentType = btn.dataset.type;
      currentStatusFilter = 'all';
      document.querySelectorAll('.type-tab').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      document.querySelectorAll('.stg-btn').forEach(function(b) { b.classList.remove('active'); });
      document.querySelector('.stg-btn[data-stg="all"]').classList.add('active');
      renderList();
    };
  });

  // Open/Closed toggle
  document.querySelectorAll('.stg-btn').forEach(function(btn) {
    btn.onclick = function() {
      currentStatusFilter = btn.dataset.stg;
      document.querySelectorAll('.stg-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      renderList();
    };
  });

  loadInbox();

  // Auto-refresh: only update list and counts, never touch the detail panel
  setInterval(function() {
    if (pendingUpdate) return;
    fetch('/api/inbox/submissions').then(function(r) { return r.json(); }).then(function(data) {
      var hadNew = allSubmissions.filter(function(s) { return s.status === 'new'; }).length;
      allSubmissions = data;
      var hasNew = allSubmissions.filter(function(s) { return s.status === 'new'; }).length;
      updateCounts(); renderList();
      // Refresh detail panel if the selected item has new messages
      if (selectedId) {
        var current = allSubmissions.find(function(s) { return s.id === selectedId; });
        if (current) {
          var oldMsgCount = 0;
          var emailBody = document.getElementById('email-body');
          var noteBody = document.getElementById('note-body');
          var hasDraft = (emailBody && emailBody.value.trim()) || (noteBody && noteBody.value.trim());
          // Only refresh if user isn't composing
          if (!hasDraft) showDetail(selectedId);
        }
      }
      if (hasNew > hadNew) document.title = '(' + hasNew + ') Inbox — Georgetown Jerseys Admin';
    }).catch(function() {});
  }, 30000);
</script>
