---
import Base from '../layouts/Base.astro';
import TrustBar from '../components/TrustBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Base
  title="Georgetown Jerseys — Youth Sports Uniforms in Georgetown, MA"
  description="Custom team uniforms, apparel, and embroidery for youth sports teams. Family-owned in Georgetown, MA since 2013. Get started today."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner container">
      <h1>Your team. Your colors. Your numbers. We handle the rest.</h1>
      <p>Georgetown's home team outfitter since 2013. Walk in, get fitted, walk out ready to play.</p>
      <div class="hero-actions">
        <a href="/order" class="btn btn-accent">Jersey Orders</a>
        <a href="/gallery" class="btn btn-secondary hero-btn-outline">View Our Work</a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Services Overview -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">What We Do</h2>
      <p class="section-sub">Full-service team outfitting. Tell us your team, your colors, your numbers — we take it from there.</p>
      <div class="services-grid">
        <ServiceCard
          icon="👕"
          title="Team Uniforms"
          description="Jerseys, shorts, socks — complete kits for every sport. Custom colors and numbers for every player."
        />
        <ServiceCard
          icon="🧥"
          title="Custom Apparel"
          description="Sweatshirts, t-shirts, warm-ups. Team-branded gear for players, coaches, and fans."
        />
        <ServiceCard
          icon="🧵"
          title="Embroidery"
          description="Professional embroidered logos, names, and numbers. Durable and sharp on any fabric."
        />
        <ServiceCard
          icon="⭐"
          title="Heat Press"
          description="Vinyl heat-press customization for quick turnaround jobs. Crisp results every time."
        />
      </div>
      <div class="services-link">
        <a href="/services" class="btn btn-secondary">See All Services</a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">How It Works</h2>
      <p class="section-sub">Getting your team outfitted is easy. Here's the process.</p>
      <div class="steps-grid">
        <div class="step">
          <div class="step-num">1</div>
          <h3>Tell Us What You Need</h3>
          <p>Fill out our order form or give us a call. Sport, colors, sizes, numbers — whatever you've got.</p>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <h3>We Outfit Your Team</h3>
          <p>We handle fittings, customization, and production. Come in for a fitting or send us the details — your call.</p>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <h3>Pick Up or Ship</h3>
          <p>Swing by the shop in Georgetown to pick up, or we'll ship them to you. Done.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title">What Coaches Say</h2>
      <div class="testimonials-grid">
        <blockquote class="testimonial card">
          <p>"Local business makes it easy for me to send my team there. They take care of everything."</p>
          <cite>— Youth Sports Coach, Georgetown</cite>
        </blockquote>
        <blockquote class="testimonial card">
          <p>"Customization process is very easy. Tell them what you need and they handle the rest."</p>
          <cite>— Team Organizer, North Shore</cite>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner />
</Base>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, rgba(43, 94, 167, 0.92), rgba(30, 68, 120, 0.95)),
      url('/images/photos/photo-10.png') center / cover no-repeat;
    color: #fff;
    padding: var(--space-16) var(--space-6);
    text-align: center;
  }

  .hero-inner {
    max-width: 800px;
  }

  .hero h1 {
    color: #fff;
    margin-bottom: var(--space-4);
  }

  .hero p {
    font-size: var(--text-lg);
    opacity: 0.9;
    margin-bottom: var(--space-8);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-btn-outline {
    border-color: #fff;
    color: #fff;
  }

  .hero-btn-outline:hover {
    background: #fff;
    color: var(--color-primary);
  }

  @media (min-width: 768px) {
    .hero {
      padding: var(--space-24) var(--space-6);
    }
  }

  /* Services grid */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .services-link {
    text-align: center;
    margin-top: var(--space-8);
  }

  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 900px;
    margin: 0 auto;
  }

  .step {
    text-align: center;
  }

  .step-num {
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    color: #fff;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-xl);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--space-4);
  }

  .step h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .step p {
    color: var(--color-neutral-600);
    max-width: 280px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .steps-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* Testimonials */
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    max-width: 800px;
    margin: 0 auto;
  }

  .testimonial {
    text-align: center;
    border-left: 4px solid var(--color-accent);
  }

  .testimonial p {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-4);
  }

  .testimonial cite {
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
  }

  @media (min-width: 768px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
