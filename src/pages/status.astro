---
import Base from '../layouts/Base.astro';
---

<Base
  title="Order Status — Georgetown Jerseys"
  description="Check the status of your order with Georgetown Jerseys."
>
  <section class="page-header">
    <div class="container">
      <h1>Order Status</h1>
      <p>Enter the email you used when placing your order to check its status.</p>
    </div>
  </section>

  <section class="section">
    <div class="container status-container">
      <form class="status-form" id="status-form">
        <label for="status-email">Email Address</label>
        <div class="status-input-row">
          <input type="email" id="status-email" placeholder="you@example.com" required />
          <button type="submit" class="btn btn-primary" id="status-btn">Check Status</button>
        </div>
      </form>

      <div id="status-result" style="display:none;"></div>
      <div id="status-notfound" style="display:none;" class="status-notfound">
        <p>We couldn't find an order with that email. If you recently placed an order, it may take a few minutes to appear.</p>
        <p>Questions? Call us at <a href="tel:+19783528240">(978) 352-8240</a>.</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-header {
    background: var(--color-primary);
    color: #fff;
    padding: var(--space-12) var(--space-6);
    text-align: center;
  }
  .page-header h1 { color: #fff; margin-bottom: var(--space-3); }
  .page-header p { opacity: 0.9; max-width: 520px; margin: 0 auto; }

  .status-container { max-width: 600px; margin: 0 auto; }

  .status-form label {
    display: block;
    margin-bottom: var(--space-2);
  }

  .status-input-row {
    display: flex;
    gap: var(--space-3);
  }

  .status-input-row input { flex: 1; }
  .status-input-row button { flex-shrink: 0; padding: 12px 24px; }

  .status-notfound {
    text-align: center;
    padding: var(--space-8);
    color: var(--color-neutral-600);
    background: var(--color-neutral-50);
    border-radius: var(--radius-xl);
    margin-top: var(--space-6);
  }

  /* Result card */
  .status-card {
    background: #fff;
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    margin-top: var(--space-6);
  }

  .status-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .status-card-team {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-xl);
  }

  .status-card-date {
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
  }

  .status-steps {
    display: flex;
    align-items: flex-start;
    margin-bottom: var(--space-6);
  }

  .status-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    text-align: center;
  }

  .status-step::after {
    content: '';
    position: absolute;
    top: 16px;
    left: calc(50% + 18px);
    right: calc(-50% + 18px);
    height: 3px;
    background: var(--color-neutral-200);
  }

  .status-step:last-child::after { display: none; }
  .status-step.past::after { background: var(--color-primary); }

  .status-dot {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--text-sm);
    border: 3px solid var(--color-neutral-200);
    background: #fff;
    color: var(--color-neutral-600);
    z-index: 1;
  }

  .status-step.past .status-dot {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }

  .status-step.current .status-dot {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-neutral-900);
    transform: scale(1.15);
    box-shadow: 0 0 0 4px rgba(232, 163, 23, 0.2);
  }

  .status-step-label {
    font-size: 10px;
    font-family: var(--font-heading);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    color: var(--color-neutral-600);
    margin-top: 8px;
    max-width: 80px;
    line-height: 1.3;
  }

  .status-step.current .status-step-label { color: var(--color-neutral-900); }
  .status-step.past .status-step-label { color: var(--color-primary); }

  .status-current-label {
    text-align: center;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-lg);
    color: var(--color-primary);
  }

  .status-help {
    text-align: center;
    margin-top: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
  }

  @media (max-width: 480px) {
    .status-input-row { flex-direction: column; }
    .status-step-label { font-size: 8px; max-width: 60px; }
    .status-dot { width: 28px; height: 28px; font-size: var(--text-xs); }
    .status-step::after { top: 13px; left: calc(50% + 15px); right: calc(-50% + 15px); }
  }
</style>

<script is:inline>
  var stages = ['review', 'production', 'ready', 'picked-up'];
  var labels = ['Received', 'In Production', 'Ready for Pickup', 'Picked Up'];

  document.getElementById('status-form').onsubmit = function(e) {
    e.preventDefault();
    var email = document.getElementById('status-email').value;
    var btn = document.getElementById('status-btn');
    btn.disabled = true; btn.textContent = 'Checking...';
    document.getElementById('status-result').style.display = 'none';
    document.getElementById('status-notfound').style.display = 'none';

    fetch('/api/status/lookup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      btn.disabled = false; btn.textContent = 'Check Status';
      if (!data.found) {
        document.getElementById('status-notfound').style.display = 'block';
        return;
      }

      var ci = stages.indexOf(data.stage);
      var date = new Date(data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

      var stepsHtml = stages.map(function(s, i) {
        var cls = i < ci ? 'past' : i === ci ? 'current' : '';
        return '<div class="status-step ' + cls + '">' +
          '<div class="status-dot">' + (i < ci ? '&#10003;' : (i + 1)) + '</div>' +
          '<div class="status-step-label">' + labels[i] + '</div></div>';
      }).join('');

      var result = document.getElementById('status-result');
      result.style.display = 'block';
      result.innerHTML = '<div class="status-card">' +
        '<div class="status-card-header">' +
          '<div class="status-card-team">' + (data.team || 'Your Order') + (data.sport ? ' — ' + data.sport : '') + '</div>' +
          '<div class="status-card-date">Ordered ' + date + '</div>' +
        '</div>' +
        '<div class="status-steps">' + stepsHtml + '</div>' +
        '<div class="status-current-label">' + data.stageLabel + '</div>' +
        '<div class="status-help">Questions? Call <a href="tel:+19783528240">(978) 352-8240</a> or reply to your order confirmation email.</div>' +
      '</div>';
    })
    .catch(function() {
      btn.disabled = false; btn.textContent = 'Check Status';
      document.getElementById('status-notfound').style.display = 'block';
    });
  };
</script>
